generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  name         String   @map("name") @db.VarChar(100)
  role         Role
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  carts         Cart[]
  transactions  Transaction[]

  @@map("users")
}

enum Role {
  cashier
  manager
  admin
}

model Category {
  id          String   @id @default(uuid())
  name        String   @map("name") @db.VarChar(100)
  slug        String   @unique @map("slug") @db.VarChar(100)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  products Product[]

  @@map("categories")
}

model Product {
  id          String   @id @default(uuid())
  sku         String   @unique @map("sku") @db.VarChar(50)
  barcode     String?  @unique @map("barcode") @db.VarChar(50)
  name        String   @map("name") @db.VarChar(255)
  description String?  @db.Text
  price       Decimal  @map("price") @db.Decimal(10, 2)
  cost        Decimal? @map("cost") @db.Decimal(10, 2)
  categoryId  String?  @map("category_id")
  imageUrl    String?  @map("image_url") @db.VarChar(500)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category     Category?     @relation(fields: [categoryId], references: [id])
  inventory    Inventory?
  cartItems    CartItem[]
  transactionItems TransactionItem[]

  @@index([categoryId], name: "idx_products_category")
  @@map("products")
}

model Inventory {
  id                String    @id @default(uuid())
  productId         String    @unique @map("product_id")
  quantity          Int       @default(0)
  lowStockThreshold Int       @default(10) @map("low_stock_threshold")
  lastRestockedAt   DateTime? @map("last_restocked_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([quantity], name: "idx_inventory_quantity")
  @@map("inventory")
}

model Cart {
  id        String    @id @default(uuid())
  userId    String?   @map("user_id")
  sessionId String?   @map("session_id") @db.VarChar(100)
  status    CartStatus @default(Active)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user  User?     @relation(fields: [userId], references: [id])
  items CartItem[]

  @@map("carts")
}

enum CartStatus {
  Active
  Converted
  Abandoned
}

model CartItem {
  id        String   @id @default(uuid())
  cartId    String   @map("cart_id")
  productId String   @map("product_id")
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  cart    Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([cartId], name: "idx_cart_items_cart")
  @@map("cart_items")
}

model Transaction {
  id             String            @id @default(uuid())
  receiptNumber  String            @unique @map("receipt_number") @db.VarChar(50)
  userId         String?           @map("user_id")
  subtotal       Decimal           @map("subtotal") @db.Decimal(10, 2)
  taxAmount      Decimal           @map("tax_amount") @db.Decimal(10, 2)
  discountAmount Decimal           @default(0) @map("discount_amount") @db.Decimal(10, 2)
  total          Decimal           @map("total") @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  amountPaid     Decimal           @map("amount_paid") @db.Decimal(10, 2)
  changeGiven    Decimal           @default(0) @map("change_given") @db.Decimal(10, 2)
  status         TransactionStatus @default(completed)
  customerName   String?           @map("customer_name") @db.VarChar(100)
  notes          String?           @db.Text
  createdAt      DateTime          @default(now()) @map("created_at")

  user  User?              @relation(fields: [userId], references: [id])
  items TransactionItem[]

  @@index([userId], name: "idx_transactions_user")
  @@index([createdAt], name: "idx_transactions_created")
  @@index([status], name: "idx_transactions_status")
  @@map("transactions")
}

enum PaymentMethod {
  cash
  card
  mixed
}

enum TransactionStatus {
  completed
  refunded
  voided
}

model TransactionItem {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  productId     String?  @map("product_id")
  productName   String   @map("product_name") @db.VarChar(255)
  productSku    String   @map("product_sku") @db.VarChar(50)
  quantity      Int
  unitPrice     Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal      Decimal  @map("subtotal") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product?    @relation(fields: [productId], references: [id])

  @@index([transactionId], name: "idx_transaction_items_transaction")
  @@map("transaction_items")
}