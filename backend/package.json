{
  "name": "pos-kiosko-backend",
  "version": "1.0.0",
  "description": "Grocery POS Backend with Express.js 5.x, TypeScript, Prisma",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
