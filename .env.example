# Root-level env file consumed by docker-compose.yml.
# Copy to `.env` and adjust as needed: `cp .env.example .env`
# All values have sensible dev defaults — uncomment only what you need to override.

# --- Postgres ---
# DB_NAME=pos_kiosko
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_PORT=5432

# --- Backend ---
# NODE_ENV=development
# BACKEND_PORT=3001
# JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# FRONTEND_URL=https://your-frontend-domain.com   # only used when NODE_ENV=production

# --- Frontend ---
# FRONTEND_PORT=5173
# VITE_API_URL=http://localhost:3001/api
