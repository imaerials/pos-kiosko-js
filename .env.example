# Root-level env file consumed by docker-compose.yml (prod) and docker-compose.dev.yml (dev).
# Copy to `.env` and adjust as needed: `cp .env.example .env`

# --- Postgres ---
# DB_NAME=pos_kiosko
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_PORT=5432        # dev only — port exposed to the host by docker-compose.dev.yml

# --- Backend ---
# JWT_SECRET=change-me-in-production   # required for docker-compose.yml (production)
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# FRONTEND_URL=https://your-frontend-domain.com
# ALLOWED_REGISTRATION_EMAILS=owner@store.com,manager@store.com   # gate /api/auth/register; leave unset for open registration

# --- Frontend (production) ---
# FRONTEND_PORT=80    # host port mapped to the nginx container
